config-file = ./themes/Custom-01
# custom-shader = shaders/cursor_smear_fade.glsl

auto-update = off
auto-update-channel = stable

command = /run/current-system/sw/bin/fish --login --interactive

font-size = 15
font-thicken = true
font-thicken-strength = 200
font-feature = zero
cursor-text = #000000

# alernate w
font-feature = cv07
# alternate 1
font-feature = cv11
# alternate 0
font-feature = cv16

adjust-cell-height = 11%

keybind = super+ctrl+h=goto_split:left
keybind = super+ctrl+l=goto_split:right
keybind = super+ctrl+k=goto_split:top
keybind = super+ctrl+j=goto_split:bottom

window-inherit-font-size = true
window-inherit-working-directory = true
window-save-state = always

shell-integration = fish
shell-integration-features = no-cursor, no-sudo, no-title
cursor-style = block
cursor-style-blink = true
macos-titlebar-style = tabs
title = " "
keybind = alt+left=esc:b
keybind = alt+right=esc:f
background-opacity = 0.89
background-blur-radius = 20

window-padding-x = 11
window-padding-y = 11

mouse-hide-while-typing = true
quick-terminal-position = bottom

unfocused-split-opacity = 1

macos-icon = chalkboard
